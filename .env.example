# ─── Auth (Phase 3) ───
# Never commit real values. Generate the hash with: npm run hash-password
ADMIN_USERNAME=troisrivers
# bcrypt hash of the admin password (output of scripts/hash-password.ts). NOT the plaintext.
ADMIN_PASSWORD_HASH=
# >= 32 random bytes, e.g. `openssl rand -base64 48`
SESSION_SECRET=
# Canonical site URL, used for the CSRF same-origin check (audit M3).
# Set in production, e.g. https://maths-blog.vercel.app
SITE_URL=


# ─── Database (Phase 2) ───
# Pooled connection for runtime queries (@vercel/postgres / Neon serverless).
POSTGRES_URL=
# Direct (non-pooled) connection for drizzle-kit migrations. REQUIRED for migrate.
POSTGRES_URL_NON_POOLING=

# ─── Blob storage (Phase 5) ───
BLOB_READ_WRITE_TOKEN=

# ─── Rate limiting (Phase 3) — Upstash Redis / Vercel KV ───
# Optional locally: if unset, login rate-limiting is skipped (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Agent API (external AI agents posting via /api/agent/**) ───
# Generate with: node scripts/generate-agent-key.mjs  (>= 32 hex chars)
# Agents send:  Authorization: Bearer <AGENT_API_KEY>
AGENT_API_KEY=
